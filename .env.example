TZ=America/Chicago
EAG_CRON_SCHEDULE=0 * * * *
EAG_IMAGE=ghcr.io/jimjudd/eero-adguard-sync:latest
EAG_DATA_VOLUME=./data

EAG_ADGUARD_HOST=http://adguard-home:3000
EAG_ADGUARD_USER=admin
EAG_ADGUARD_PASSWORD=change-me

EAG_EERO_USER=you@example.com

# Set exactly one of these when your Eero account has multiple networks.
EAG_EERO_NETWORK_ID=
EAG_EERO_NETWORK_NAME=

# Optional behavior flags for the sync command.
EAG_DELETE=false
EAG_OVERWRITE=false

# Optional override if you want to inject a pre-captured Eero session cookie.
EAG_EERO_COOKIE=
